{
  "name": "@verevoir/storage",
  "version": "0.3.0-beta.3",
  "description": "Database-agnostic storage adapter with Postgres reference implementation",
  "homepage": "https://verevoir.io",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:verevoir/storage-adapter.git"
  },
  "funding": "https://buymeacoffee.com/verevoir",
  "scripts": {
    "prepare": "npm run build",
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/pg": "^8.18.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  }
}
